  epic-decomposer:
    system_prompt: "{{SODORYARD_AGENTS_DIR}}/edward.md"
    tools:
      - brain
      - file:read
      - search
    brain_write_paths:
      - "epics/**"
      - "receipts/epic-decomposer/**"
      - "logs/epic-decomposer/**"
    brain_deny_paths:
      - "specs/**"
